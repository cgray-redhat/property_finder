# Database — PostgreSQL with PostGIS
# Use a PostGIS-enabled image locally, e.g. postgis/postgis:16-3.4
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/property_finder?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# RentCast API — server-side only (never expose to the client)
# Get your key at https://app.rentcast.io/app/api
RENTCAST_API_KEY="your_rentcast_api_key_here"

# Mapbox — client-side map tiles (public token is OK)
# Get your token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="your_mapbox_public_token_here"

# PostHog — product analytics (client-side public key is OK)
# Get your key at https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_project_api_key_here"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
