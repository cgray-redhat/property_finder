# =============================================================================
# Production / Vercel staging — set in Vercel Project → Settings → Environment
# Variables (Preview + Production scopes as appropriate).
# =============================================================================
#
# Required
#   DATABASE_URL                          PostgreSQL + PostGIS connection string
#   RENTCAST_API_KEY                      RentCast listings + market API (server)
#   NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN       Mapbox GL map tiles (client)
#   NEXT_PUBLIC_APP_URL                   Canonical app URL, e.g. https://app.example.com
#
# Recommended
#   USE_MLS_FIXTURE_DATA=false            Disable saved MLS fixture in production
#   NEXT_PUBLIC_USE_MLS_FIXTURE_DATA=false
#
# Optional
#   NEXT_PUBLIC_POSTHOG_KEY               Product analytics
#   NEXT_PUBLIC_POSTHOG_HOST              Default https://us.i.posthog.com
#   NEXT_PUBLIC_MLS_FIXTURE_ZIP=27519     Only if fixture mode enabled
#
# Not required (no server API integration today)
#   Zillow — links are address-based URLs built in the browser; no Zillow API token.
#   Realtor.com — redirect route uses Realtor's public geocoder; no API token.
#
# GitHub Actions secrets (for .github/workflows/deploy.yml)
#   VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
#
# =============================================================================

# Database — PostgreSQL with PostGIS
# Use a PostGIS-enabled image locally, e.g. postgis/postgis:16-3.4
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/property_finder?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# RentCast API — server-side only (never expose to the client)
# Get your key at https://app.rentcast.io/app/api
RENTCAST_API_KEY="your_rentcast_api_key_here"

# MLS fixture mode — set false in production; true locally to avoid RentCast usage
USE_MLS_FIXTURE_DATA="true"
NEXT_PUBLIC_USE_MLS_FIXTURE_DATA="true"
NEXT_PUBLIC_MLS_FIXTURE_ZIP="27519"

# Mapbox — client-side map tiles (public token is OK)
# Get your token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="your_mapbox_public_token_here"

# PostHog — product analytics (client-side public key is OK)
# Get your key at https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_project_api_key_here"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
